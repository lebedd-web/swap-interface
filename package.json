{
  "name": "turborepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "start:web": "pnpm --filter web start",
    "clean": "rm -rf apps/*/.next apps/*/.turbo packages/*/.turbo .turbo",
    "tsc": "pnpm clean && turbo tsc",
    "format": "turbo format",
    "lint": "pnpm clean && turbo lint",
    "lint:fix": "pnpm clean && turbo lint:fix",
    "check": "pnpm tsc && pnpm lint",
    "precommit:check": "pnpm tsc && pnpm format && pnpm lint",
    "pipeline:check": "pnpm lint && pnpm tsc",
    "storybook:ui": "pnpm --filter @library/ui storybook",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "turbo": "^2.4.2"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  }
}
